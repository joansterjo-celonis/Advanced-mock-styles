# Copy to .env.local for local development (.env.local is gitignored; this file is committed).
# Only variables prefixed with VITE_ are exposed to the client bundle.

# ---- Feedback + shared theme library (JSONBin.io) ----
# The feedback feature and the synced theme library read these. Without a key
# the feature still works but only against the browser's localStorage (no sharing).
# NOTE: this is a static client build, so the key ships in the public bundle.
# Use an access-gated prototype key, not a sensitive account master key you reuse elsewhere.
VITE_JSONBIN_KEY=

# Bin ids (these have safe defaults baked into src/scripts/cloud-store.js; override only if needed)
VITE_JSONBIN_FEEDBACK_BIN=6a3a29afda38895dfeefd1c8
VITE_JSONBIN_THEMES_BIN=6a3a2d92da38895dfeefdfb6

# Override the Pages base path for other hosts (e.g. "/" for a root/custom domain).
# Defaults to /Advanced-mock-styles/ when unset.
# VITE_BASE=/Advanced-mock-styles/
